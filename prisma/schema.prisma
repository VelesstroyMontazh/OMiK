model MainDatabase {
  id           String   @id @default(cuid())
  name         String   @default("Основная БД")
  originalName String
  filePath     String
  totalRows    Int      @default(0)
  totalCols    Int      @default(0)
  sheetName    String   @default("Лист1")
  fileSize     Int      @default(0)
  keyColumns   String   @default("0,1,2,3,4,5,6,8,10,11,12,13")
  isActive     Boolean  @default(true)
  loadedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
