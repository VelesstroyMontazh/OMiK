# Скопируйте в .env.local (Next.js) — см. docs/LOCAL_SETUP.md

# --- Next.js / Prisma ---
DATABASE_URL=file:./db/custom.db
EXCEL_BACKEND_URL=http://127.0.0.1:3031
# Для загрузки .xlsm >10 MB из браузера напрямую на excel-service (те же хост/порт)
NEXT_PUBLIC_EXCEL_BACKEND_URL=http://127.0.0.1:3031
# Загрузка файлов напрямую на :3031 (быстрее для пачки 10+ Excel)
NEXT_PUBLIC_OMIK_DIRECT_UPLOAD=1

# --- Excel-service (FastAPI / uvicorn) ---
PORT=3031
EXCEL_SERVICE_HOST=127.0.0.1
UVICORN_WORKERS=1
# Через запятую; пусто = localhost:3000 и :81
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:81,http://localhost:81

# Данные билетов/календаря вне папки проекта (Windows: %LOCALAPPDATA%\OMiK_VSM\data)
# OMIK_DATA_DIR=C:\Users\YOU\AppData\Local\OMiK_VSM\data

# --- Caddy (опционально) ---
# CADDY_PORT=81

# Опционально: защита /api/excel/* и FastAPI (заголовок X-OMIK-Token)
# OMIK_API_SECRET=change-me-to-a-long-random-string

# --- Celery + Redis (ОПЦИОНАЛЬНО; по умолчанию не используется — см. ЗАПУСК-Celery.md) ---
# OMIK_USE_CELERY=1
# OMIK_REDIS_URL=redis://127.0.0.1:6379/0
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
