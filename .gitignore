```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Environment variables
.env
.env.local
*.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Python cache (if any Python files exist in project)
__pycache__/
*.pyc
*.pyo
*.pyd

# Temporary files
*.tmp
*.temp

# OS specific
.DS_Store
Thumbs.db

# Testing
.nyc_output/
.mypy_cache/
.pytest_cache/
.tox/

# Compiled binaries
*.exe
*.dll
*.so
*.a
*.o
*.obj
*.out

# Archives
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```