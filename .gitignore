```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.bundle.js
*.bundle.css

# Environment variables
.env
.env.local
*.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
*.coverage

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled binary files
*.exe
*.dll
*.so
*.dylib

# Compressed files
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.rar
*.7z
*.bz2
*.xz
*.zst

# OS generated files
.DS_Store
Thumbs.db
```